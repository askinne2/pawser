{
  "name": "pawser",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "db:generate": "pnpm --filter @pawser/database db:generate",
    "db:push": "pnpm --filter @pawser/database db:push",
    "db:migrate": "pnpm --filter @pawser/database db:migrate",
    "db:studio": "pnpm --filter @pawser/database db:studio",
    "db:seed": "pnpm --filter @pawser/database db:seed"
  },
  "devDependencies": {
    "turbo": "^1.10.16",
    "typescript": "^5.2.2"
  },
  "packageManager": "pnpm@8.10.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}

