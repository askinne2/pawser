# Pawser Platform - Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================
# Database Configuration
# ============================================
# Using port 5434 to avoid conflicts with other PostgreSQL instances (default is 5432)
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/pawser

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# API Server Configuration
# ============================================
PORT=3002
NODE_ENV=development

# JWT Authentication
# Generate a secure JWT secret with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Or use: openssl rand -base64 32
JWT_SECRET=HVaYjhc74UzH4d+XyvOP4V6xCMwKbnmw3dTaLLZexh4=
JWT_EXPIRES_IN=24h

# Development Auth Bypass (ONLY for local development)
# Set to 'true' to bypass authentication in dev mode (NOT for production!)
DEV_AUTH_BYPASS=false

# Encryption (for ShelterLuv API keys)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-me-in-production-use-strong-key-64-chars-hex

# CORS Configuration
CORS_ORIGIN=*

# ============================================
# Admin Dashboard Configuration
# ============================================
# API URL for admin dashboard to connect to API server
API_URL=http://localhost:3002

# ============================================
# Portal Configuration
# ============================================
# Public API URL (used by portal frontend)
NEXT_PUBLIC_API_URL=http://localhost:3002

# ============================================
# Pawser Platform Configuration
# ============================================
# Base domain for tenant subdomains
PAWSER_BASE_DOMAIN=pawser.app

# ============================================
# ShelterLuv API Configuration (for reference)
# ============================================
# These are used when configuring organizations in the admin dashboard
# Each organization will have its own API key stored encrypted in the database
# 
# Example ShelterLuv API endpoint:
# SHELTERLUV_API_URL=https://www.shelterluv.com/api/v1
# 
# Example adoption URL base:
# SHELTERLUV_ADOPT_URL_BASE=https://new.shelterluv.com/matchme/adopt/
