// Prisma schema for Pawser multi-tenant platform
// Based on PRD-08: Database Schema & Multi-Tenancy

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Core Identity Tables
// ============================================

model Organization {
  id               String    @id @default(uuid())
  name             String    @db.VarChar(255)
  slug             String    @unique @db.VarChar(64)
  status           String    @default("active") @db.VarChar(32) // active, suspended, disabled, trial
  stripeCustomerId String?   @map("stripe_customer_id") @db.VarChar(255)
  timezone         String    @default("America/New_York") @db.VarChar(64)
  logoUrl          String?   @map("logo_url") @db.VarChar(2048)
  primaryColor     String?   @map("primary_color") @db.VarChar(7) // #RRGGBB
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  // Relations
  memberships            Membership[]
  domainMappings         DomainMapping[]
  integrationCredentials IntegrationCredential[]
  dataSources            DataSource[]
  locations              Location[]
  animals                Animal[]
  mediaAssets            MediaAsset[]
  syncRuns               SyncRun[]
  syncStates             SyncState[]
  webhookEvents          WebhookEvent[]
  auditLogs              AuditLog[]
  subscriptions          Subscription[]
  invoices               Invoice[]
  apiTokens              ApiToken[]
  magicLinks             MagicLink[]
  settings               OrganizationSetting[]
  invitations            Invitation[]
  emailLogs              EmailLog[]
  settingsV2             OrganizationSettings?

  @@index([slug])
  @@index([status])
  @@index([stripeCustomerId])
  @@map("organizations")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique @db.VarChar(320)
  name         String?   @db.VarChar(255)
  isSuperAdmin Boolean   @default(false) @map("is_super_admin")
  disabled     Boolean   @default(false)
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  memberships           Membership[]
  passwordCredential    PasswordCredential?
  magicLinks            MagicLink[]
  apiTokensCreated      ApiToken[]           @relation("ApiTokenCreator")
  auditLogs             AuditLog[]
  syncRunsCreated       SyncRun[]
  membershipInvitations Membership[]         @relation("InvitedBy")
  passwordResetTokens   PasswordResetToken[]
  invitationsSent       Invitation[]
  refreshTokens         RefreshToken[]

  @@index([email])
  @@index([isSuperAdmin])
  @@map("users")
}

model PasswordCredential {
  userId            String   @id @map("user_id")
  passwordHash      String   @map("password_hash") @db.VarChar(255)
  passwordUpdatedAt DateTime @default(now()) @map("password_updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_credentials")
}

model Membership {
  id              String    @id @default(uuid())
  orgId           String    @map("org_id")
  userId          String    @map("user_id")
  role            String    @default("viewer") @db.VarChar(16) // owner, admin, viewer
  invitedByUserId String?   @map("invited_by_user_id")
  acceptedAt      DateTime? @map("accepted_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy    User?        @relation("InvitedBy", fields: [invitedByUserId], references: [id])

  @@unique([orgId, userId])
  @@index([orgId])
  @@index([userId])
  @@map("memberships")
}

// ============================================
// Domain & Access Tables
// ============================================

model DomainMapping {
  id                 String    @id @default(uuid())
  orgId              String    @map("org_id")
  domain             String    @unique @db.VarChar(255)
  isPrimary          Boolean   @default(false) @map("is_primary")
  verificationStatus String    @default("pending") @map("verification_status") @db.VarChar(32) // pending, verified, failed
  sslStatus          String    @default("pending") @map("ssl_status") @db.VarChar(32) // pending, active, expired
  cloudflareZoneId   String?   @map("cloudflare_zone_id") @db.VarChar(64)
  dnsValidationToken String?   @map("dns_validation_token") @db.VarChar(64)
  verifiedAt         DateTime? @map("verified_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([domain])
  @@map("domain_mappings")
}

model MagicLink {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  orgId      String?   @map("org_id")
  tokenHash  String    @map("token_hash") @db.VarChar(64)
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("magic_links")
}

model ApiToken {
  id              String    @id @default(uuid())
  orgId           String    @map("org_id")
  name            String    @db.VarChar(255)
  tokenHash       String    @map("token_hash") @db.VarChar(64)
  scopes          String    @default("read") @db.VarChar(255) // read, write, admin
  lastUsedAt      DateTime? @map("last_used_at")
  expiresAt       DateTime? @map("expires_at")
  createdByUserId String    @map("created_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("ApiTokenCreator", fields: [createdByUserId], references: [id])

  @@index([orgId])
  @@index([tokenHash])
  @@map("api_tokens")
}

// ============================================
// Integration & Data Source Tables
// ============================================

model IntegrationCredential {
  id                String    @id @default(uuid())
  orgId             String    @map("org_id")
  provider          String    @default("shelterluv") @db.VarChar(32) // shelterluv, petpoint, etc.
  accountLabel      String?   @map("account_label") @db.VarChar(255)
  externalAccountId String?   @map("external_account_id") @db.VarChar(128)
  scope             String?   @db.VarChar(64) // animals, locations, all
  secretCiphertext  String    @map("secret_ciphertext") @db.Text
  secretIv          String    @map("secret_iv") @db.Text
  secretTag         String    @map("secret_tag") @db.Text
  encVersion        Int       @default(1) @map("enc_version")
  status            String    @default("active") @db.VarChar(32) // active, invalid, revoked
  lastValidatedAt   DateTime? @map("last_validated_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  dataSources  DataSource[]

  @@index([orgId])
  @@index([provider])
  @@map("integration_credentials")
}

model DataSource {
  id                String   @id @default(uuid())
  orgId             String   @map("org_id")
  provider          String   @default("shelterluv") @db.VarChar(32)
  credentialsId     String   @map("credentials_id")
  externalAccountId String?  @map("external_account_id") @db.VarChar(128)
  name              String   @db.VarChar(255)
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  organization Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  credentials  IntegrationCredential @relation(fields: [credentialsId], references: [id], onDelete: Cascade)
  locations    Location[]
  animals      Animal[]
  syncRuns     SyncRun[]
  syncStates   SyncState[]

  @@index([orgId])
  @@index([credentialsId])
  @@index([isActive])
  @@map("data_sources")
}

// ============================================
// Location & Animal Tables
// ============================================

model Location {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  dataSourceId String   @map("data_source_id")
  externalId   String   @map("external_id") @db.VarChar(128)
  name         String   @db.VarChar(255)
  address      String?  @db.Text
  city         String?  @db.VarChar(128)
  state        String?  @db.VarChar(64)
  postalCode   String?  @map("postal_code") @db.VarChar(32)
  phone        String?  @db.VarChar(32)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  dataSource   DataSource   @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  animals      Animal[]

  @@unique([orgId, dataSourceId, externalId])
  @@index([orgId])
  @@index([dataSourceId])
  @@map("locations")
}

model Animal {
  id              String    @id @default(uuid())
  orgId           String    @map("org_id")
  dataSourceId    String    @map("data_source_id")
  externalId      String    @map("external_id") @db.VarChar(128)
  locationId      String?   @map("location_id")
  name            String    @db.VarChar(255)
  slug            String    @db.VarChar(255)
  species         String    @db.VarChar(64) // dog, cat, bird, rabbit, other
  breedPrimary    String?   @map("breed_primary") @db.VarChar(128)
  breedSecondary  String?   @map("breed_secondary") @db.VarChar(128)
  ageYears        Int?      @map("age_years")
  ageMonths       Int?      @map("age_months")
  sex             String?   @db.VarChar(16) // male, female, unknown
  size            String?   @db.VarChar(16) // small, medium, large, xlarge
  color           String?   @db.VarChar(64)
  status          String    @default("available") @db.VarChar(32) // available, pending, adopted, foster, hold
  description     String?   @db.Text
  attributes      Json?     @default("{}") // goodWithKids, goodWithDogs, goodWithCats, houseTrained, etc.
  published       Boolean   @default(false)
  publishedAt     DateTime? @map("published_at")
  intakeDate      DateTime? @map("intake_date") @db.Date
  birthDate       DateTime? @map("birth_date") @db.Date
  adoptionUrl     String?   @map("adoption_url") @db.VarChar(2048)
  lastSeenAt      DateTime? @map("last_seen_at")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  dataSource   DataSource   @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  location     Location?    @relation(fields: [locationId], references: [id])
  mediaAssets  MediaAsset[]

  @@unique([orgId, dataSourceId, externalId])
  @@index([orgId, published, status])
  @@index([orgId, species])
  @@index([orgId, status])
  @@index([slug])
  @@map("animals")
}

model MediaAsset {
  id         String   @id @default(uuid())
  orgId      String   @map("org_id")
  animalId   String   @map("animal_id")
  r2Key      String?  @map("r2_key") @db.VarChar(512)
  url        String   @db.VarChar(2048)
  isPrimary  Boolean  @default(false) @map("is_primary")
  orderIndex Int      @default(0) @map("order_index")
  width      Int?
  height     Int?
  etag       String?  @db.VarChar(128)
  sha256     String?  @db.VarChar(64)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  animal       Animal       @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@index([animalId, isPrimary])
  @@index([orgId])
  @@map("media_assets")
}

// ============================================
// Sync & Webhook Tables
// ============================================

model SyncRun {
  id              String    @id @default(uuid())
  orgId           String    @map("org_id")
  dataSourceId    String    @map("data_source_id")
  startedAt       DateTime  @default(now()) @map("started_at")
  finishedAt      DateTime? @map("finished_at")
  status          String    @default("running") @db.VarChar(16) // running, completed, failed
  error           String?   @db.Text
  itemsFetched    Int       @default(0) @map("items_fetched")
  itemsUpserted   Int       @default(0) @map("items_upserted")
  itemsDeleted    Int       @default(0) @map("items_deleted")
  trigger         String    @default("scheduled") @db.VarChar(16) // scheduled, manual, webhook
  createdByUserId String?   @map("created_by_user_id")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  dataSource   DataSource   @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation(fields: [createdByUserId], references: [id])

  @@index([orgId])
  @@index([dataSourceId])
  @@index([status])
  @@map("sync_runs")
}

model SyncState {
  id            String    @id @default(uuid())
  orgId         String    @map("org_id")
  dataSourceId  String    @map("data_source_id")
  resource      String    @db.VarChar(32) // animals, locations
  cursor        Json?     @default("{}")
  lastSyncedAt  DateTime? @map("last_synced_at")
  nextEligibleAt DateTime? @map("next_eligible_at")
  backoffSeconds Int       @default(0) @map("backoff_seconds")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  dataSource   DataSource   @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)

  @@unique([orgId, dataSourceId, resource])
  @@index([orgId])
  @@index([dataSourceId])
  @@map("sync_state")
}

model WebhookEvent {
  id          String    @id @default(uuid())
  orgId       String?   @map("org_id")
  provider    String    @db.VarChar(32) // stripe, shelterluv
  eventType   String    @map("event_type") @db.VarChar(128)
  externalId  String    @map("external_id") @db.VarChar(255)
  payload     Json
  receivedAt  DateTime  @default(now()) @map("received_at")
  processedAt DateTime? @map("processed_at")
  status      String    @default("pending") @db.VarChar(16) // pending, processed, failed
  error       String?   @db.Text

  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([provider])
  @@index([externalId])
  @@index([status])
  @@map("webhook_events")
}

// ============================================
// Audit & Security Tables
// ============================================

model AuditLog {
  id          String   @id @default(uuid())
  orgId       String?  @map("org_id")
  actorUserId String?  @map("actor_user_id")
  actorType   String   @default("user") @map("actor_type") @db.VarChar(16) // user, system, api
  action      String   @db.VarChar(64) // create, update, delete, login, etc.
  entityType  String   @map("entity_type") @db.VarChar(64) // organization, animal, etc.
  entityId    String?  @map("entity_id")
  metadata    Json?    @default("{}")
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  createdAt   DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  actorUser    User?         @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([actorUserId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// Billing Tables
// ============================================

model Plan {
  id                  String   @id @default(uuid())
  code                String   @unique @db.VarChar(32) // trial, basic, pro, enterprise
  name                String   @db.VarChar(64)
  description         String?  @db.Text
  syncIntervalSeconds Int      @default(900) @map("sync_interval_seconds") // 15 min default
  maxAdmins           Int      @default(2) @map("max_admins")
  priceCents          Int      @default(0) @map("price_cents")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@index([code])
  @@index([isActive])
  @@map("plans")
}

model Subscription {
  id                   String    @id @default(uuid())
  orgId                String    @map("org_id")
  planId               String    @map("plan_id")
  status               String    @default("trialing") @db.VarChar(32) // trialing, active, past_due, canceled, paused
  stripeCustomerId     String?   @map("stripe_customer_id") @db.VarChar(255)
  stripeSubscriptionId String?   @map("stripe_subscription_id") @db.VarChar(255)
  trialEnd             DateTime? @map("trial_end")
  currentPeriodEnd     DateTime? @map("current_period_end")
  cancelAt             DateTime? @map("cancel_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId], references: [id])

  @@index([orgId])
  @@index([planId])
  @@index([status])
  @@index([stripeSubscriptionId])
  @@map("subscriptions")
}

model Invoice {
  id               String    @id @default(uuid())
  orgId            String    @map("org_id")
  stripeInvoiceId  String    @unique @map("stripe_invoice_id") @db.VarChar(255)
  status           String    @default("draft") @db.VarChar(32) // draft, open, paid, void, uncollectible
  amountDueCents   Int       @default(0) @map("amount_due_cents")
  amountPaidCents  Int       @default(0) @map("amount_paid_cents")
  periodStart      DateTime? @map("period_start")
  periodEnd        DateTime? @map("period_end")
  hostedInvoiceUrl String?   @map("hosted_invoice_url") @db.VarChar(2048)
  createdAt        DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([status])
  @@map("invoices")
}

// ============================================
// Settings Table (for themes and misc config)
// ============================================

model OrganizationSetting {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  key            String   @db.VarChar(64)
  value          Json
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId])
  @@map("organization_settings")
}

// ============================================
// Password Reset & Invitations Tables
// ============================================

model PasswordResetToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  tokenHash   String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt   DateTime  @map("expires_at")
  consumedAt  DateTime? @map("consumed_at")
  ipAddress   String?   @map("ip_address") @db.VarChar(45)
  userAgent   String?   @map("user_agent") @db.VarChar(512)
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Invitation {
  id           String    @id @default(uuid())
  orgId        String    @map("org_id")
  email        String    @db.VarChar(320)
  role         String    @default("admin") @db.VarChar(16) // owner, admin, viewer
  tokenHash    String    @unique @map("token_hash") @db.VarChar(64)
  message      String?   @db.Text
  invitedById  String    @map("invited_by_id")
  expiresAt    DateTime  @map("expires_at")
  acceptedAt   DateTime? @map("accepted_at")
  cancelledAt  DateTime? @map("cancelled_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation(fields: [invitedById], references: [id])

  @@index([orgId])
  @@index([email])
  @@index([tokenHash])
  @@map("invitations")
}

model RefreshToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  tokenHash   String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  ipAddress   String?   @map("ip_address") @db.VarChar(45)
  userAgent   String?   @map("user_agent") @db.VarChar(512)
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

// ============================================
// Email Logging Table
// ============================================

model EmailLog {
  id          String    @id @default(uuid())
  orgId       String?   @map("org_id")
  type        String    @db.VarChar(32) // magic-link, invitation, password-reset, trial-ending, etc.
  to          String    @db.VarChar(320)
  subject     String    @db.VarChar(255)
  messageId   String?   @map("message_id") @db.VarChar(255) // Resend message ID
  status      String    @default("pending") @db.VarChar(32) // pending, sent, delivered, failed, bounced
  error       String?   @db.Text
  sentAt      DateTime? @map("sent_at")
  deliveredAt DateTime? @map("delivered_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  organization Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([to])
  @@index([type])
  @@index([status])
  @@map("email_logs")
}

// ============================================
// Organization Settings (White-Label) Table
// ============================================

model OrganizationSettings {
  id              String   @id @default(uuid())
  orgId           String   @unique @map("org_id")
  
  // General
  contactEmail    String?  @map("contact_email") @db.VarChar(320)
  phone           String?  @db.VarChar(32)
  address         String?  @db.Text
  timezone        String   @default("America/New_York") @db.VarChar(64)
  locale          String   @default("en-US") @db.VarChar(16)
  
  // Social
  websiteUrl      String?  @map("website_url") @db.VarChar(2048)
  facebookUrl     String?  @map("facebook_url") @db.VarChar(2048)
  instagramUrl    String?  @map("instagram_url") @db.VarChar(2048)
  twitterUrl      String?  @map("twitter_url") @db.VarChar(2048)
  
  // Branding
  logoUrl         String?  @map("logo_url") @db.VarChar(2048)
  faviconUrl      String?  @map("favicon_url") @db.VarChar(2048)
  primaryColor    String   @default("#3B82F6") @map("primary_color") @db.VarChar(7)
  secondaryColor  String   @default("#64748B") @map("secondary_color") @db.VarChar(7)
  backgroundColor String   @default("#F9FAFB") @map("background_color") @db.VarChar(7)
  textPrimary     String   @default("#111827") @map("text_primary") @db.VarChar(7)
  textSecondary   String   @default("#6B7280") @map("text_secondary") @db.VarChar(7)
  headingFont     String   @default("system") @map("heading_font") @db.VarChar(64)
  bodyFont        String   @default("system") @map("body_font") @db.VarChar(64)
  
  // Portal
  showLogo        Boolean  @default(true) @map("show_logo")
  showOrgName     Boolean  @default(true) @map("show_org_name")
  navLinks        Json     @default("[]") @map("nav_links") // [{label, url}]
  showContactInfo Boolean  @default(true) @map("show_contact_info")
  showSocialLinks Boolean  @default(true) @map("show_social_links")
  footerText      String?  @map("footer_text") @db.Text
  copyrightText   String?  @map("copyright_text") @db.VarChar(255)
  ctaButtonText   String   @default("Apply to Adopt") @map("cta_button_text") @db.VarChar(64)
  ctaButtonUrl    String?  @map("cta_button_url") @db.VarChar(2048)
